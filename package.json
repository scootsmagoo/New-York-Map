{
  "name": "new-york-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An interactive, pannable timeline of New York City's history, from Lenapehoking to Greater New York (1919). Inspired by Gotham by Burrows & Wallace.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "validate:wiki": "node scripts/validate-wiki-titles.mjs",
    "prepare:overlays": "node scripts/prepare-overlays.mjs"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "mapshaper": "^0.7.22",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
